# Freddo Matcha — environment variables
# Copy to .env.local and fill in real values. Anything left empty falls back
# to a safe no-op (analytics calls become no-ops, email capture stashes
# signups in localStorage so we don't lose pre-launch interest).

# --- Analytics (each optional, fan-out in lib/analytics.ts) ---

# PostHog — primary product analytics
# Get from https://eu.posthog.com/project/{id}/settings → Project API Key
NEXT_PUBLIC_POSTHOG_KEY=
# Default eu.i.posthog.com. Override only if self-hosting.
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Google Analytics 4 — acquisition tracking
NEXT_PUBLIC_GA4_ID=

# Meta (Facebook/Instagram) Pixel — ad attribution
NEXT_PUBLIC_META_PIXEL_ID=

# --- Email capture (Klaviyo) ---
# Without these, EmailCapture stashes signups in localStorage and tracks
# the email_captured event. With these, it POSTs directly to Klaviyo's
# legacy v2 subscribe endpoint.
NEXT_PUBLIC_KLAVIYO_PUBLIC_KEY=
NEXT_PUBLIC_KLAVIYO_LIST_ID=
